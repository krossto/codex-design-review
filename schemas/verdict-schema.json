{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "findings"],
  "properties": {
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "confidence", "summary"],
      "properties": {
        "overall": {
          "type": "string",
          "enum": ["approved", "revise"],
          "description": "approved = no significant findings. revise = there are findings to address"
        },
        "confidence": {
          "type": "number",
          "description": "0.0-1.0. Overall confidence of the review"
        },
        "summary": {
          "type": "string",
          "description": "Brief overall summary"
        }
      }
    },
    "findings": {
      "type": "array",
      "description": "Actionable findings only. Each must include a concrete suggestion",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "section", "issue", "why", "suggestion"],
        "properties": {
          "id": {"type": "string", "description": "Sequential id: F1, F2, ..."},
          "severity": {"type": "string", "enum": ["critical", "important", "minor"]},
          "section": {"type": "string", "description": "Target section name / heading"},
          "issue": {"type": "string", "description": "What is the problem"},
          "why": {"type": "string", "description": "Why it is a problem"},
          "suggestion": {"type": "string", "description": "Concrete suggested fix"}
        }
      }
    }
  }
}
